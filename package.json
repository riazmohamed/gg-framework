{
  "name": "gg-framework",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "check": "pnpm -r check",
    "lint": "eslint packages/*/src/",
    "lint:fix": "eslint packages/*/src/ --fix",
    "format": "prettier --write packages/*/src/",
    "format:check": "prettier --check packages/*/src/",
    "test": "pnpm -r test",
    "prepare": "pnpm build"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["onnxruntime-node"],
    "overrides": {
      "global-agent": "^4.1.3"
    }
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "tsup": "^8.5.1",
    "typescript-eslint": "^8.59.0"
  }
}
