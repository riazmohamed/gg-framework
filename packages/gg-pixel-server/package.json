{
  "name": "@kenkaiiii/gg-pixel-server",
  "version": "4.3.85",
  "private": true,
  "type": "module",
  "description": "Cloudflare Workers backend for gg-pixel",
  "scripts": {
    "check": "tsc --noEmit",
    "test": "vitest run",
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:local": "wrangler d1 migrations apply gg-pixel --local",
    "db:remote": "wrangler d1 migrations apply gg-pixel --remote"
  },
  "dependencies": {
    "hono": "^4.6.13"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241218.0",
    "@types/better-sqlite3": "^7.6.12",
    "better-sqlite3": "^11.7.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4",
    "wrangler": "^3.99.0"
  }
}
