{
  "name": "@kenkaiiii/gg-editor-premiere-panel",
  "version": "0.1.0",
  "type": "module",
  "description": "CEP panel that exposes Adobe Premiere Pro to gg-editor via a local HTTP server. Required for Premiere on Windows.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kenkaiiii/gg-framework.git",
    "directory": "packages/gg-editor-premiere-panel"
  },
  "bin": {
    "gg-editor-premiere-panel": "./dist/bin/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/src/index.js",
      "types": "./dist/src/index.d.ts"
    }
  },
  "files": [
    "dist",
    "panel"
  ],
  "scripts": {
    "build": "tsc",
    "check": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "chalk": "^5.6.2"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4"
  },
  "publishConfig": {
    "access": "public"
  }
}
